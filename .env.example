# PostgreSQL (docker compose up -d; порт 5433, чтобы не конфликтовать с локальным Postgres)
DATABASE_URL="postgresql://app:app@localhost:5433/senior_practice"

# MongoDB (docker compose up -d)
MONGODB_URI="mongodb://localhost:27017/senior_practice"

# Auth.js — сгенерировать: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""

# OAuth-провайдеры (опционально в dev: без них вход недоступен, но приложение работает)
# GitHub: https://github.com/settings/developers → New OAuth App
#   Homepage URL: http://localhost:3000, Callback: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Google: https://console.cloud.google.com/apis/credentials
#   Callback: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
