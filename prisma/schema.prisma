generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Auth.js ──────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  submissions  Submission[]
  reviews      ReviewState[]
  bookmarks    Bookmark[]
  mockSessions MockSession[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Контент ──────────────────────────────────────────────────────────

enum QuestionType {
  theory
  quiz
}

/// Порядок объявления важен: используется для сортировки (senior > middle > junior)
enum Difficulty {
  junior
  middle
  senior
}

enum ContentStatus {
  draft
  published
}

/// Вопрос из content/questions/**; источник истины — markdown в git, загрузка через `npm run seed`.
/// Пользовательские данные (Bookmark, ReviewState) ссылаются на slug — он стабилен между пересозданиями БД.
model Question {
  id          String        @id @default(cuid())
  slug        String        @unique
  type        QuestionType  @default(theory)
  topic       String
  tags        String[]
  difficulty  Difficulty
  title       String
  body        String
  answer      String
  quizOptions Json?
  followUps   String[]
  references  Json          @default("[]")
  status      ContentStatus @default(published)
  version     Int           @default(1)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status, topic])
  @@index([status, difficulty])
}

// ── Домен ────────────────────────────────────────────────────────────

enum SubmissionStatus {
  PASSED
  FAILED
  ERROR
}

enum ItemType {
  QUESTION
  CHALLENGE
}

/// Попытка решения coding-задачи (challengeSlug — slug задачи, фаза 2)
model Submission {
  id            String           @id @default(cuid())
  userId        String
  challengeSlug String
  language      String
  code          String
  status        SubmissionStatus
  passedTests   Int
  totalTests    Int
  durationMs    Int?
  createdAt     DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, challengeSlug])
  @@index([userId, createdAt])
}

/// Состояние spaced repetition (SM-2) для вопроса
model ReviewState {
  id           String   @id @default(cuid())
  userId       String
  questionSlug String
  easeFactor   Float    @default(2.5)
  interval     Int      @default(0)
  repetition   Int      @default(0)
  dueAt        DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, questionSlug])
  @@index([userId, dueAt])
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  itemSlug  String
  itemType  ItemType
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, itemSlug, itemType])
}

/// Сессия mock-интервью: config — параметры, items — вопросы/задачи и самооценки
model MockSession {
  id         String    @id @default(cuid())
  userId     String
  config     Json
  items      Json
  score      Int?
  startedAt  DateTime  @default(now())
  finishedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startedAt])
}
